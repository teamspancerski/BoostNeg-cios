{
  "buildCommand": "cd frontend && npx next build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "installCommand": "cd frontend && npm install",
  "functions": {
    "frontend/src/app/api/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "ignore": ["api/", "apps/", ".nx/"]
}
