generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  stripeId  String   @unique
  email     String
  agents    String   @default("[]")
  createdAt DateTime @default(now())
}
