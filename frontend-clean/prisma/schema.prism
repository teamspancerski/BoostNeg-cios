generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  stripeId  String   @unique
  email     String
  agents    Json     @default("[]")
  createdAt DateTime @default(now())
}
